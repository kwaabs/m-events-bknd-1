# Copy to .env and fill in your values. Never commit .env.

APP_ENV=development
PORT=9400

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=9432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=ecg
DB_SSLMODE=disable

# ── LDAP / Active Directory ───────────────────────────────────────────────────
LDAP_URL=ldap://dc.example.com:389

# Domain appended to the username to form the UPN for AD bind.
# e.g. LDAP_USER_DOMAIN=example.com → binds as jdoe@example.com
# Leave empty if your server accepts bare usernames or full DNs directly.
LDAP_USER_DOMAIN=example.com

# Search base used to fetch user attributes (display name, email, groups)
# after a successful bind. The user reads their own entry so no admin needed.
LDAP_BASE_DN=DC=example,DC=com

# Filter to locate the user entry. %s is replaced with the sanitised username.
LDAP_USER_FILTER=(sAMAccountName=%s)

# Encryption — pick ONE or neither (plain is fine on internal networks)
# Set true for ldaps:// (port 636)
LDAP_USE_SSL=false
# Set true to upgrade a plain port-389 connection via StartTLS
LDAP_STARTTLS=false
# Set true only in dev to skip TLS certificate verification
LDAP_SKIP_VERIFY=false

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY=8h
JWT_ISSUER=github.com/kwaabs/m-events

# ── Martin tile server ────────────────────────────────────────────────────────
# Internal URL — not exposed publicly, only used by the Go API tile proxy
MARTIN_URL=http://martin:9401

# ── Valkey (cache + token blacklist) ─────────────────────────────────────────
VALKEY_URL=redis://valkey:9479

# ── Dev accounts (APP_ENV=development only) ───────────────────────────────────
# Only active when APP_ENV=development — ignored in production.
# Generate a bcrypt hash with: make hash-password password=yourpassword
#
DEV_ACCOUNT_1_USERNAME=dev
DEV_ACCOUNT_1_DISPLAY_NAME=Dev User
DEV_ACCOUNT_1_EMAIL=dev@ecg.local
# Default password: devpass123  — change before sharing
# IMPORTANT: bcrypt hashes contain $ signs. In your .env file these are fine.
# But if you ever reference them directly in docker-compose.yml, use $$ to escape.
DEV_ACCOUNT_1_PASSWORD_HASH=$2a$10$YourBcryptHashHere

# Add more accounts if needed:
# DEV_ACCOUNT_2_USERNAME=analyst
# DEV_ACCOUNT_2_DISPLAY_NAME=Analyst User
# DEV_ACCOUNT_2_EMAIL=analyst@ecg.local
# DEV_ACCOUNT_2_PASSWORD_HASH=$2a$10$...

# ── Valkey rate limiting + cache ──────────────────────────────────────────────
# Lock account after N failed logins within the window (0 = disabled)
VALKEY_MAX_FAILED_LOGINS=5
VALKEY_FAILED_LOGIN_WINDOW=15m
# How long to cache dashboard summary responses
VALKEY_DASHBOARD_CACHE_TTL=60s